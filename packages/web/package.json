  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.2.0",
    "svelte-check": "^4.0.9",
    "tslib": "^2.8.1",
    "vite": "^6.0.0"
  }
}
