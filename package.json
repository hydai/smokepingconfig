{
  "name": "smokepingconf-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w @smokepingconf/web run dev",
    "build": "npm --workspaces --if-present run build",
    "preview": "npm -w @smokepingconf/web run preview",
    "check": "npm --workspaces --if-present run check",
    "test": "npm --workspaces --if-present run test",
    "test:e2e": "npm -w @smokepingconf/web run test:e2e",
    "prebuild": "npm -w @smokepingconf/core run prebuild",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.9.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
